{
  "manifest_version": 3,
  "name": "Amazon Listing Quality Analyzer",
  "description": "Analyzes Amazon product listings for quality and provides a delta review score for strengths and weaknesses",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://www.amazon.com/*",
    "*://www.amazon.co.uk/*",
    "*://www.amazon.de/*",
    "*://www.amazon.fr/*",
    "*://www.amazon.co.jp/*",
    "*://www.amazon.ca/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.amazon.com/*",
        "*://www.amazon.co.uk/*",
        "*://www.amazon.de/*",
        "*://www.amazon.fr/*",
        "*://www.amazon.co.jp/*",
        "*://www.amazon.ca/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}